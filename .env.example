# Configuración del Frontend
# Copiar este archivo a .env y configurar las variables

# URL del backend API
VITE_API_URL=http://localhost:3001

# Usar backend PHP en lugar de Node.js (true/false)
VITE_USE_PHP_BACKEND=false

# Otras configuraciones
VITE_APP_NAME="Fundación Estoy Contigo"
VITE_APP_VERSION=1.0.0