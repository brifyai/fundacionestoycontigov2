# Configuración del servidor
PORT=3001
FRONTEND_URL=http://localhost:5173

# Configuración de email (SMTP)
# Para Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password

# Email de destino para los mensajes de contacto
CONTACT_EMAIL=contacto@estoycontigo.cl

# Nota: Para Gmail, necesitas generar una "App Password" en tu cuenta de Google
# Ve a: Seguridad > Verificación en dos pasos > Contraseñas de aplicaciones